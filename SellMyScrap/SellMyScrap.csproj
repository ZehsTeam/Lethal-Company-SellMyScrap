<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <ProduceReferenceAssembly>false</ProduceReferenceAssembly>
    
    <AssemblyName_>com.github.zehsteam.$(MSBuildProjectName)</AssemblyName_> <!-- PLUGIN_GUID -->
    <Product_>$(MSBuildProjectName)</Product_>                               <!-- PLUGIN_NAME -->
    <Version>1.15.3</Version>                                                <!-- PLUGIN_VERSION -->
    <Authors>Zehs</Authors>
    <Description_>Adds a few terminal commands to sell your scrap from the ship or cruiser. Highly Configurable. Compatible with the ShipInventoryUpdated mod. SellFromTerminal +</Description_>
    <Copyright>Copyright © 2026 Zehs</Copyright>
    
    <RootNamespace>com.github.zehsteam.$(MSBuildProjectName)</RootNamespace>
    
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    
    <DebugSymbols>true</DebugSymbols>
    <DebugType>embedded</DebugType>
    
    <!-- Trim the project path in debug symbols -->
    <PathMap>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)'))=./</PathMap>
    
    <RestoreAdditionalProjectSources>
      https://api.nuget.org/v3/index.json;
      https://nuget.bepinex.dev/v3/index.json;
      https://nuget.samboy.dev/v3/index.json;
    </RestoreAdditionalProjectSources>
  </PropertyGroup>

  <!-- Lethal Company version toggle -->
  <!-- "73" for v73+ -->
  <!-- "72" for v40/v72 -->
  <PropertyGroup>
    <LCVersion>73</LCVersion>
  </PropertyGroup>
  
  <PropertyGroup>
    <DefineConstants>$(DefineConstants);LC_VERSION_$(LCVersion)</DefineConstants>
  </PropertyGroup>
  
  

  <!-- v73+ properties -->
  <PropertyGroup Condition="'$(LCVersion)' == '73'">
    <AssemblyName>$(AssemblyName_)</AssemblyName>
    <Product>$(Product_)</Product>
    <Description>[v73+] $(Description_)</Description>
  </PropertyGroup>
  
  <PropertyGroup Condition="'$(LCVersion)' == '73'">
    <OutputPath>bin\$(Configuration)\v73+\</OutputPath>
  </PropertyGroup>
  
  <!-- v40/v72 properties -->
  <PropertyGroup Condition="'$(LCVersion)' == '72'">
    <AssemblyName>$(AssemblyName_).v40-v72</AssemblyName>
    <Product>$(Product_)</Product>
    <Description>[v40/v72] $(Description_)</Description>
  </PropertyGroup>
  
  <PropertyGroup Condition="'$(LCVersion)' == '72'">
    <OutputPath>bin\$(Configuration)\v40-v72\</OutputPath>
  </PropertyGroup>
  
  
  
  <Target Name="ClearReferenceCopyLocalPaths" AfterTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)" />
    </ItemGroup>
  </Target>
  
  <ItemGroup Condition="'$(TargetFramework.TrimEnd(`0123456789`))' == 'net'">
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.2" PrivateAssets="all" />
  </ItemGroup>
  
  <ItemGroup>
    <None Include="..\README.md" Link="README.md" />
  </ItemGroup>
  
  <!-- AssetBundle file -->
  <ItemGroup>
    <None Condition="Exists('$(AssetBundleFilePath)')" Include="$(AssetBundleFilePath)" Link="$(AssetBundleFileName)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  
  
  
  <!-- dependencies -->
  <ItemGroup>
    <PackageReference Include="BepInEx.AssemblyPublicizer.MSBuild" Version="0.4.3" PrivateAssets="all" />
    <PackageReference Include="BepInEx.Analyzers" Version="1.*" PrivateAssets="all" />
    <PackageReference Include="BepInEx.Core" Version="5.4.21" />
    <PackageReference Include="BepInEx.PluginInfoProps" Version="2.*" PrivateAssets="all" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>
  
  <!-- v73+ dependencies -->
  <ItemGroup Condition="'$(LCVersion)' == '73'">
    <PackageReference Include="UnityEngine.Modules" Version="2022.3.62" IncludeAssets="compile" PrivateAssets="all" />
    
    <!-- This is not working for NetcodePatcher for some reason? -->
    <!--<PackageReference Include="LethalCompany.GameLibs.Steam" Version="81.0.0-ngd.0" PrivateAssets="all" />-->
  </ItemGroup>
  
